# Brand
NEXT_PUBLIC_BRAND_ID=axeon

# Upstash Redis (Managed Trial ledger / locks / rate limit)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin console at /admin/trial (list / revoke / privileged issue)
TRIAL_ADMIN_SECRET=

# Public /trial self-serve issue (default OFF). Set on only if intentionally open.
# TRIAL_PUBLIC_ISSUE=on
TRIAL_PUBLIC_ISSUE=off

# Server-only Provider secrets (Trial uses OPENAI only)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Managed Trial defaults (OpenAI allowlist only)
TRIAL_DEFAULT_MODEL=gpt-5.4-nano
