{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [
    "index.ts",
    "demo-core/**/*.ts",
    "trial/**/*.ts",
    "providers/**/*.ts",
    "types/**/*.ts",
    "config/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
